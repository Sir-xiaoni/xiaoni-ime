<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="280dp"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF0A1628">

    <!-- 顶部状态栏 -->
    <TextView
        android:id="@+id/app_name_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="小逆输入法"
        android:textSize="20sp"
        android:textColor="#FF00D4FF"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginTop="16dp" />

    <!-- 科幻装饰线 -->
    <View
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:background="#FF00D4FF"
        android:layout_marginTop="8dp" />

    <!-- 状态文本 -->
    <TextView
        android:id="@+id/voice_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击麦克风开始说话"
        android:textSize="16sp"
        android:textColor="#FF88CCFF"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 麦克风按钮 -->
        <ImageButton
            android:id="@+id/mic_button"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_mic_off"
            android:background="@drawable/btn_mic_background"
            android:scaleType="centerInside"
            android:padding="20dp"
            android:contentDescription="开始/停止识别" />

        <!-- 间隔 -->
        <View
            android:layout_width="40dp"
            android:layout_height="0dp" />

        <!-- 说完了按钮 -->
        <ImageButton
            android:id="@+id/stop_button"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/btn_send_background"
            android:scaleType="centerInside"
            android:padding="20dp"
            android:contentDescription="说完了，发送" />

    </LinearLayout>

    <!-- 底部提示 -->
    <TextView
        android:id="@+id/hint_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI 语音识别 · 点击麦克风开始"
        android:textSize="12sp"
        android:textColor="#FF5588AA"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp" />

</LinearLayout>