<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/voice_panel"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/voice_panel_background"
    android:visibility="gone">

    <TextView
        android:id="@+id/voice_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击麦克风开始说话"
        android:textSize="18sp"
        android:textColor="@color/voice_text_color"
        android:layout_marginBottom="20dp" />

    <ProgressBar
        android:id="@+id/voice_volume_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="10dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/volume_progress"
        android:layout_marginBottom="30dp" />

    <ImageButton
        android:id="@+id/voice_stop_button"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_mic_off"
        android:background="@drawable/voice_button_background"
        android:contentDescription="停止语音输入" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击停止"
        android:textSize="14sp"
        android:textColor="@color/voice_hint_color"
        android:layout_marginTop="10dp" />

</LinearLayout>
